# Count from 1 to 1 billion.

7f 52 56 4d                # magic
01 00                      # abi_ver
00                         # type (RTYP_EXEC)
20 00 00 00 00 00 00 00    # entry
00 00 00 00 00 00 00 00    # datoff
00 00 00 00 00 00 00 00    # datlen

00                         # (padding)

03 00 00 00 00 00 00 00    # mov %r0, #0 ; the counter
03 10 e8 03 00 00 00 00    # mov %r1, #1000 ; increment
03 20 00 ca 9a 3b 00 00    # mov %r2, #1_000_000_000 ; the limit
3b 00 02 00 00 00 00 00    # _loop: cmp %r0, %r2
54 00 01 00 00 00 00 00    # jge _end
10 00 01 00 00 00 00 00    # add %r0, %r0, %r1
50 80 03 00 00 00 00 00    # jmp _loop
03 00 7f 00 00 00 00 00    # _end: mov %r0, #127
01 00 00 00 00 00 00 00    # ivc #0
