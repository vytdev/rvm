# Count from 1 to 1 billion.

7f 52 56 4d                # magic
01 00                      # abi_ver
00                         # type (RTYP_EXEC)
00   # (padding)
00 00 00 00 00 00 00 00    # entry
30 00 00 00 00 00 00 00    # codoff
04 00 00 00 00 00 00 00    # codlen
00 00 00 00 00 00 00 00    # datoff
00 00 00 00 00 00 00 00    # datlen

04 00 00 00 ca 9a 3b 00    # mov %r0, #1_000_000_000 ; the loop count
92 00 00 ff ff ff ff ff    # _loop: loop %r0, _loop
04 00 00 7f 00 00 00 00    # mov %r0, #127
01 00 00 00 00 00 00 00    # ivc #0
