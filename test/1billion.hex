# Count from 1 to 1 billion.

7f 52 56 4d                # magic
01 00                      # abi_ver
00                         # type (RHT_LOADABLE)
00                         # flags
00 00 00 00 00 00 00 00    # entryp
68 00 00 00 00 00 00 00    # shoff
01 00 00 00 00 00 00 00    # shnum
60 00 00 00 00 00 00 00    # stroff
00 00 00 00 00 00 00 00    # (padding)
00 00 00 00 00 00 00 00    # (padding)
00 00 00 00 00 00 00 00    # (padding)

# .code section:
04 00 00 00 ca 9a 3b 00    # mov %r0, #1_000_000_000 ; the loop count
92 00 00 ff ff ff ff ff    # _loop: loop %r0, _loop
04 00 00 7f 00 00 00 00    # mov %r0, #127
01 00 00 00 00 00 00 00    # ivc #0

# strtab:
00 2e 63 6f 64 65 00 00    # .code

# shtab (for code section):
01 00 00 00                # name
00 00 00 00                # (padding)
40 00 00 00 00 00 00 00    # offset
20 00 00 00 00 00 00 00    # size
04 00 00 00 00 00 00 00    # entcnt
