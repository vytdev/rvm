# Trigger an S_ILL error.

7f 52 56 4d                # magic
01 00                      # abi_ver
00                         # type (RTYP_EXEC)
20 00 00 00 00 00 00 00    # entry
00 00 00 00 00 00 00 00    # datoff
00 00 00 00 00 00 00 00    # datlen

00                         # (padding)

79 00 00 ff ff ff ff ff    # jmp <somewhere_else>
01 00 00 00 00 00 00 00    # ivc #0
